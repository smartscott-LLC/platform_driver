generate_target all [get_files  /home/smartscott/platform_driver/tb3d.srcs/sources_1/bd/design_1/design_1.bd]
export_ip_user_files -of_objects [get_files /home/smartscott/platform_driver/tb3d.srcs/sources_1/bd/design_1/design_1.bd] -no_script -sync -force -quiet
export_simulation -lib_map_path [list {modelsim=/home/smartscott/platform_driver/tb3d.cache/compile_simlib/modelsim} {questa=/home/smartscott/platform_driver/tb3d.cache/compile_simlib/questa} {xcelium=/home/smartscott/platform_driver/tb3d.cache/compile_simlib/xcelium} {vcs=/home/smartscott/platform_driver/tb3d.cache/compile_simlib/vcs} {riviera=/home/smartscott/platform_driver/tb3d.cache/compile_simlib/riviera}] -of_objects [get_files /home/smartscott/platform_driver/tb3d.srcs/sources_1/bd/design_1/design_1.bd] -directory /home/smartscott/platform_driver/tb3d.ip_user_files/sim_scripts -ip_user_files_dir /home/smartscott/platform_driver/tb3d.ip_user_files -ipstatic_source_dir /home/smartscott/platform_driver/tb3d.ip_user_files/ipstatic -use_ip_compiled_libs -force -quiet
update_compile_order -fileset sources_1
make_wrapper -files [get_files /home/smartscott/platform_driver/tb3d.srcs/sources_1/bd/design_1/design_1.bd] -top
make_wrapper -files [get_files /home/smartscott/platform_driver/tb3d.srcs/sources_1/bd/design_1/design_1.bd] -top
startgroup
create_bd_cell -type ip -vlnv xilinx.com:ip:versal_cips:3.4 versal_cips_0
endgroup
set_property -dict [list \
  CONFIG.CPM_CONFIG { \
    CPM_PCIE0_MODES {None} \
    CPM_PRESET {QDMA_Controller0_MMST_1PF_G4x8_TandemPCIe} \
  } \
  CONFIG.PS_PMC_CONFIG { \
    DESIGN_MODE {1} \
    PCIE_APERTURES_DUAL_ENABLE {0} \
    PCIE_APERTURES_SINGLE_ENABLE {1} \
    PMC_USE_NOC_PMC_AXI0 {1} \
    PMC_USE_PMC_NOC_AXI0 {1} \
    PS_BOARD_INTERFACE {Custom} \
    PS_PCIE1_PERIPHERAL_ENABLE {1} \
    PS_PCIE2_PERIPHERAL_ENABLE {0} \
    PS_PCIE_RESET {ENABLE 1} \
    SMON_ALARMS {Set_Alarms_On} \
    SMON_ENABLE_TEMP_AVERAGING {0} \
    SMON_TEMP_AVERAGING_SAMPLES {0} \
  } \
] [get_bd_cells versal_cips_0]
connect_bd_net [get_bd_pins tb3d_engine_top_0/intr_req] [get_bd_pins versal_cips_0/cpm_irq0]
